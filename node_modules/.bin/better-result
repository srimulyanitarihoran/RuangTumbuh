#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules/better-result/node_modules:/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules:/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules/better-result/node_modules:/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules:/mnt/c/Users/LENOVO/Documents/RuangTumbuh/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../better-result/bin/cli.mjs" "$@"
else
  exec node  "$basedir/../better-result/bin/cli.mjs" "$@"
fi
