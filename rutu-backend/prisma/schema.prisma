// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// TABEL PENGGUNA (Akun & Saldo Waktu)
model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  timeBalance    Int      @default(30)
  profilePicture String?
  location       String?  @default("Indonesia")
  birthday       String?
  school         String?
  description    String?
  passions       Json?    
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // --- RELASI USER ---
  skillsOffered   UserSkill[]
  bookingsAsTutor Booking[]      @relation("TutorSessions")
  bookingsAsSiswa Booking[]      @relation("StudentSessions")
  forumPosts      ForumPost[]
  forumComments   ForumComment[]
  messages        Message[]      // Menggantikan sentMessages & recvMessages
  chatRooms       Participant[]
}

// TABEL SKILL (KETERAMPILAN YANG BISA DITUKAR)
model Skill {
  id          String      @id @default(uuid())
  name        String      @unique // Contoh: "Matematika", "Desain Grafis", "Inggris"
  description String?

  // Relasi
  users       UserSkill[]
  bookings    Booking[]
}

// TABEL PENGHUBUNG (Siswa Mana Yang Menawarkan Skill Apa)
model UserSkill {
  id      String @id @default(uuid())
  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId]) // 1 user tidak bisa input skill yang sama 2 kali
}

// TABEL Course BOOKING (Pemesanan Sesi Belajar)
model Booking {
  id              String   @id @default(uuid())
  tutorId         String   
  studentId       String   
  skillId         String?  
  scheduledAt     DateTime 
  durationMinutes Int      
  status          Status   @default(PENDING) 
  meetingLink     String?  
  notes           String?  
  createdAt       DateTime @default(now())

  verificationToken String?  
  isVerified        Boolean  @default(false)
  disputeReason     String?  

  tutor   User   @relation("TutorSessions", fields: [tutorId], references: [id])
  student User   @relation("StudentSessions", fields: [studentId], references: [id])
  skill   Skill? @relation(fields: [skillId], references: [id])

  review  Review?

  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([scheduledAt])
}

// TABEL REVIEW (Ulasan & Rating setelah sesi terverifikasi)
model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  rating      Int      // Contoh: 1 sampai 5 bintang
  feedback    String?  // Komentar dari siswa untuk tutor
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

enum Status {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELED
  DISPUTED
}

model ForumPost {
  id        String   @id @default(uuid())
  authorId  String
  title     String
  content   String
  createdAt DateTime @default(now())

  author   User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments ForumComment[]
}

model ForumComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// TABEL PUSAT COURSE
model Course {
  id          Int      @id @default(autoincrement())
  name        String
  tutor       String
  tutorId     String   @default("") 
  kategori    String
  durasi      String
  deskripsi   String
  modules     Json?    
  createdAt   DateTime @default(now())

  bookings    CourseBooking[]

  // Mempercepat fitur pencarian (Search) berdasarkan kategori atau tutor
  @@index([kategori])
  @@index([tutorId])
}

// TABEL BOOKING KURSUS (Siswa -> Course yang dibuat Mentor)
model CourseBooking {
  id          String              @id @default(uuid())
  courseId    Int                 
  studentId   String          
  studentName String              
  scheduledAt DateTime            
  note        String?
  status      CourseBookingStatus @default(PENDING)
  token       String?            
  rating      Int?              
  review      String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@index([scheduledAt])
}

enum CourseBookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// MODEL UNTUK FITUR CHAT & KOMUNITAS
model ChatRoom {
  id          String         @id @default(uuid())
  name        String?        // Kosong jika chat pribadi, diisi nama jika ini grup/komunitas
  isGroup     Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  messages    Message[]
  participants Participant[]
}

model Message {
  id          String   @id @default(uuid())
  text        String   @db.Text
  createdAt   DateTime @default(now())
  
  senderId    String
  roomId      String
  
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  room        ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([roomId])
}

// Tabel relasi Many-to-Many antara User dan ChatRoom
model Participant {
  userId      String
  roomId      String
  joinedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId]) // Composite primary key
}
